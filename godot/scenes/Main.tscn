[gd_scene load_steps=8 format=3]

; Minimal bootstrap scene: a lit room-ish floor viewed through the VHS filter.
; It exists so the project opens and runs out of the box — replace/expand the
; 3D side with your real level. The CanvasLayer + ColorRect apply the shader.

[ext_resource type="Shader" path="res://shaders/vhs.gdshader" id="1_vhs"]
[ext_resource type="Script" path="res://scripts/vhs_controller.gd" id="2_ctrl"]

[sub_resource type="ShaderMaterial" id="ShaderMaterial_1"]
